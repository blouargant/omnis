# agent-toolkit environment example
#
# Usage:
#   cp .env.example .env
#   # edit values
#   source .env
#
# Default provider is openai_compat. OPENAI_BASE_URL is required.

# Provider selection (default if unset: openai_compat)
export GOAGENT_PROVIDER=openai_compat

# Model selection (optional; defaults to gpt-4o-mini for openai_compat)
export GOAGENT_MODEL=gpt-4o-mini

# OpenAI-compatible endpoint (required for openai_compat)
# Examples:
#   http://localhost:11434/v1
#   https://api.groq.com/openai/v1
#   https://llm-gateway.example.com/v1
export OPENAI_BASE_URL=http://localhost:11434/v1

# API key (optional for some local providers; required for hosted providers)
export OPENAI_API_KEY=your-openai-compatible-key

# Alternative providers (uncomment what you use)
# export GOAGENT_PROVIDER=openai
# export OPENAI_API_KEY=your-openai-key
# export GOAGENT_MODEL=gpt-4o-mini

# export GOAGENT_PROVIDER=anthropic
# export ANTHROPIC_API_KEY=your-anthropic-key
# export GOAGENT_MODEL=claude-sonnet-4-5

# export GOAGENT_PROVIDER=gemini
# export GOOGLE_API_KEY=your-google-api-key
# # or: export GEMINI_API_KEY=your-gemini-api-key
# export GOAGENT_MODEL=gemini-2.5-flash
