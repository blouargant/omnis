{
  "name": "pytest",
  "version": 3,
  "description": "Condensed pytest output: failures with locations and summary line",
  "match": {
    "command": "pytest",
    "exclude_flags": [
      "--tb=no",
      "--co",
      "--collect-only"
    ]
  },
  "inject": {
    "args": [
      "--tb=line",
      "-q"
    ],
    "skip_if_present": [
      "--tb=",
      "-q",
      "--quiet",
      "--co",
      "--collect-only",
      "-v",
      "--verbose"
    ]
  },
  "streams": [
    "stdout",
    "stderr"
  ],
  "pipeline": [
    {
      "action": "strip_ansi"
    },
    {
      "action": "remove_lines",
      "pattern": "^[.FEsxX]+\\s+\\[\\d+%\\]"
    },
    {
      "action": "remove_lines",
      "pattern": "^\\s*$"
    },
    {
      "action": "remove_lines",
      "pattern": "^[=_ ]+$"
    },
    {
      "action": "remove_lines",
      "pattern": "^\\s*short test summary info\\s*$"
    },
    {
      "action": "keep_lines",
      "pattern": "(^FAILED |\\d+ (passed|failed|error).* in \\d)"
    },
    {
      "action": "replace",
      "pattern": "^=+ | =+$",
      "replacement": ""
    },
    {
      "action": "compact_path"
    },
    {
      "action": "truncate_lines",
      "max": 120
    },
    {
      "action": "head",
      "n": 30,
      "overflow_msg": "... more failures truncated"
    }
  ],
  "on_error": "passthrough",
  "tests": [
    {
      "name": "all passing with -q output",
      "input": "..........                                                               [100%]\n10 passed in 0.45s\n",
      "expected": "10 passed in 0.45s\n"
    },
    {
      "name": "failures with -q --tb=line output",
      "input": "..F.F                                                                    [100%]\nFAILED test_math.py::test_add - assert 3 == 4\nFAILED test_math.py::test_sub - assert 1 == 0\n2 failed, 3 passed in 0.12s\n",
      "expected": "FAILED test_math.py::test_add - assert 3 == 4\nFAILED test_math.py::test_sub - assert 1 == 0\n2 failed, 3 passed in 0.12s\n"
    },
    {
      "name": "verbose output with decorators",
      "input": "============================= test session starts ==============================\ncollected 3 items\n\ntest_module.py::test_one PASSED\ntest_module.py::test_two FAILED\n\n=================================== FAILURES ===================================\n_____________________________ test_two _____________________________________\n\nFAILED test_module.py::test_two - AssertionError\n=========================== short test summary info ============================\nFAILED test_module.py::test_two - AssertionError\n========================= 1 failed, 1 passed in 0.05s =========================\n",
      "expected": "FAILED test_module.py::test_two - AssertionError\nFAILED test_module.py::test_two - AssertionError\n1 failed, 1 passed in 0.05s\n"
    }
  ]
}
