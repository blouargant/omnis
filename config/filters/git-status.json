{
  "name": "git-status",
  "version": 2,
  "description": "Compact git status: porcelain lines plus status code summary",
  "match": {
    "command": "git",
    "subcommand": "status",
    "exclude_flags": [
      "--porcelain",
      "--short",
      "-s"
    ]
  },
  "inject": {
    "args": [
      "--porcelain"
    ],
    "skip_if_present": [
      "--porcelain",
      "--short",
      "-s"
    ]
  },
  "pipeline": [
    {
      "action": "keep_lines",
      "pattern": "\\S"
    },
    {
      "action": "group_by",
      "pattern": "^(.{2})",
      "format": "{{.Key}}: {{.Count}}",
      "append": true
    }
  ],
  "on_error": "passthrough"
}
