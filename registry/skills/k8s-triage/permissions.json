{
  "permissions": {
    "allow": [
      "Bash(kubectl get *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl logs *)",
      "Bash(kubectl top *)",
      "Bash(kubectl explain *)",
      "Bash(kubectl version *)",
      "Bash(kubectl cluster-info *)",
      "Bash(kubectl api-resources *)",
      "Bash(kubectl api-versions *)",
      "Bash(kubectl auth can-i *)",
      "Bash(kubectl config current-context *)",
      "Bash(kubectl config get-contexts *)",
      "Bash(kubectl config view *)",
      "Bash(kubectl config get-clusters *)",
      "Bash(kubectl config get-users *)",
      "Bash(kubectl diff *)",
      "Bash(kubectl wait *)"
    ],
    "ask": [
      {
        "regex": "\\bkubectl\\s+(apply|delete|patch|edit|scale|rollout|drain|cordon|uncordon|create|replace|exec|cp|port-forward|annotate|label|taint|set)\\b",
        "reason": "kubectl operation with cluster side effects — confirm namespace and target before running",
        "tools": ["Bash"]
      },
      {
        "regex": "\\bkubectl\\s+--context\\s",
        "reason": "explicit --context selects a non-default cluster — confirm the target cluster",
        "tools": ["Bash"]
      }
    ]
  }
}
