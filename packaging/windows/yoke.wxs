<?xml version="1.0" encoding="utf-8"?>
<!--
  WiX v4/v5 source for the yoke Windows MSI (x64).

  Built in CI on a windows-latest runner by .github/workflows/release.yml,
  which unpacks the goreleaser-produced yoke_<ver>_Windows_x86_64.zip into a
  staging tree and invokes:

    wix build packaging\windows\yoke.wxs -arch x64 \
      -d Version=<x.y.z.0> -d StageDir=<abs path to stage> \
      -o yoke_<ver>_windows_x86_64.msi

  Expected staging layout (produced by the workflow):

    <StageDir>\install\yoke.exe
    <StageDir>\install\yoke-server.exe
    <StageDir>\install\web\...            -> C:\Program Files\Yoke\web
    <StageDir>\data\agents.json, ...      -> C:\ProgramData\Yoke
    <StageDir>\data\server.yaml
    <StageDir>\data\filters\...
    <StageDir>\data\registry\agents\...
    <StageDir>\data\registry\skills\...

  Install layout mirrors the Linux FHS package: binaries + static web UI under
  Program Files (read-only); the bundled config + registry (the system layer of
  yoke's config search chain) under ProgramData, refreshed on upgrade. User
  overrides belong in %USERPROFILE%\.yoke, which keeps higher precedence — see
  YOKE_SYSTEM_CONFIG_DIR in internal/paths/paths.go.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
      Name="Yoke"
      Manufacturer="Bertrand Louargant"
      Version="$(var.Version)"
      UpgradeCode="615e65a6-085c-4603-80b9-7b5bc8839a0e"
      Scope="perMachine"
      Compressed="yes">

    <SummaryInformation Description="Yoke — multi-agent harness (CLI + HTTP API/Web UI server)" />

    <!-- Remove the previous version on upgrade; block downgrades. -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of Yoke is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Add/Remove Programs metadata. -->
    <Property Id="ARPHELPLINK" Value="https://github.com/blouargant/yoke" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/blouargant/yoke" />

    <!-- ===== Directory tree ===== -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Yoke">
        <Directory Id="WEBDIR" Name="web" />
      </Directory>
    </StandardDirectory>
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="DATAFOLDER" Name="Yoke" />
    </StandardDirectory>

    <!-- ===== Binaries + machine environment ===== -->
    <ComponentGroup Id="Binaries" Directory="INSTALLFOLDER">
      <Component Id="YokeCli" Bitness="always64">
        <File Id="yoke.exe" Source="$(var.StageDir)\install\yoke.exe" KeyPath="yes" />
      </Component>

      <Component Id="YokeServer" Bitness="always64">
        <File Id="yoke_server.exe" Source="$(var.StageDir)\install\yoke-server.exe" KeyPath="yes" />

        <!-- A fresh shell finds the binaries on PATH, and both binaries locate
             their bundled (non-embedded) assets without any user setup.
             YOKE_SYSTEM_CONFIG_DIR relocates only the system config layer, so
             %USERPROFILE%\.yoke and .\.agents keep their higher precedence. -->
        <Environment Id="PathAppend" Name="PATH"
                     Value="[INSTALLFOLDER]" Part="last" Action="set" System="yes" Permanent="no" />
        <Environment Id="WebDir" Name="YOKE_WEB_DIR"
                     Value="[INSTALLFOLDER]web" Action="set" System="yes" Permanent="no" />
        <Environment Id="SysCfgDir" Name="YOKE_SYSTEM_CONFIG_DIR"
                     Value="[DATAFOLDER]" Action="set" System="yes" Permanent="no" />
      </Component>
    </ComponentGroup>

    <!-- ===== Static web UI (read-only, under Program Files) ===== -->
    <ComponentGroup Id="WebAssets" Directory="WEBDIR">
      <Files Include="$(var.StageDir)\install\web\**" />
    </ComponentGroup>

    <!-- ===== Bundled config + registry (system layer, under ProgramData) ===== -->
    <ComponentGroup Id="DataAssets" Directory="DATAFOLDER">
      <Files Include="$(var.StageDir)\data\**" />
    </ComponentGroup>

    <!-- ===== Feature ===== -->
    <Feature Id="Main" Title="Yoke" Level="1">
      <ComponentGroupRef Id="Binaries" />
      <ComponentGroupRef Id="WebAssets" />
      <ComponentGroupRef Id="DataAssets" />
    </Feature>
  </Package>
</Wix>
